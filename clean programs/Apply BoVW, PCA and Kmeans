splits     = ["train","val","holdout"]

out_root.mkdir(parents=True, exist_ok=True)
new_rows = []  # staged rows for tiles (metadata append is commented below)

def slice_grid(ref_path: Path, split: str):
    """
    Cut a grid image into IMG_SIZE tiles and save to out_root/<split>.
    Returns number of tiles saved.
    """
    img = Image.open(ref_path).convert("RGB")
    W, H = img.size
    cols = W // IMG_SIZE
    rows = H // IMG_SIZE
    if cols == 0 or rows == 0:
        print(f"[WARN] {ref_path} not divisible by {IMG_SIZE}; skipping.")
        return 0

    # Output dir for this split (e.g., expr/results/afhq_all_fake_tiles/train)
    out_dir = out_root/split
    out_dir.mkdir(parents=True, exist_ok=True)

    saved = 0
    for r in range(rows):
        for c in range(cols):
            # Common grid convention: first column is the unmodified source image.
            # We skip it so only generated variants are kept as 'fake' tiles.
            if c == 0: continue
            tile = img.crop((c*IMG_SIZE, r*IMG_SIZE, (c+1)*IMG_SIZE, (r+1)*IMG_SIZE))
            fname = f"{split}_r{r:04d}_c{c:04d}.png"
            fpath = out_dir/fname
            tile.save(fpath, "PNG")

            # Stage a metadata-like dict for this tile (actual append below is commented)
            new_rows.append({
                "id": fpath.stem,
                "path": str(fpath),
                "split": split,
                "species_src": "",         # unknown from the grid alone
                "species_tgt": "",
                "label": "fake",
                "gen_family": "stargan_v2",
                "seed": "",
                "ref_id": "",
                "source": "generated_grid"
            })
            saved += 1
    return saved

# Iterate train/val/holdout grids and slice if present
total_saved = 0
for sp in splits:
    ref = in_root/f"{sp}_all"/"reference.jpg"
    if ref.exists():
        print(f"Slicing {ref} ...")
        total_saved += slice_grid(ref, sp)
    else:
        print(f"[INFO] No {ref} (did sampling finish for {sp}?)")

print(f"\nSaved {total_saved} tiles to {out_root}")

