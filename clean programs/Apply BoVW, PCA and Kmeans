    eps = 1e-12
    sparsity = (H == 0).mean(axis=1)
    probs = H / (H.sum(axis=1, keepdims=True) + eps)
    ent = -np.sum(probs * np.log(probs + eps), axis=1) / np.log(H.shape[1])

    print(f"Histogram sparsity: mean={sparsity.mean():.3f}, std={sparsity.std():.3f}")
