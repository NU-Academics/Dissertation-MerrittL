# STEP 4 — Convert StarGAN-v2 "reference.jpg" grids into per-image tiles
# Each grid typically has columns where col 0 can be the source; code skips c == 0 by default.
# Outputs go to expr/results/afhq_all_fake_tiles/<split> and (optionally) append to a metadata CSV.

# --- SETTINGS ---
IMG_SIZE = 256  # StarGAN v2 default

from pathlib import Path
from PIL import Image
import os, pandas as pd, re

base_drive = Path("/content/stargan-v2")
in_root    = base_drive/"expr/results/afhq_all_fake_stargan"  # where reference.jpg grids live
out_root   = base_drive/"expr/results/afhq_all_fake_tiles"    # where extracted tiles will be written
meta_path  = base_drive/"data/afhq_all_metadata.csv"          # optional metadata file to append to
splits     = ["train","val","holdout"]

out_root.mkdir(parents=True, exist_ok=True)
new_rows = []  # staged metadata rows to append

def slice_grid(ref_path: Path, split: str):
    """Slice a reference grid image into IMG_SIZE tiles and save them under out_root/split."""
    img = Image.open(ref_path).convert("RGB")
    W, H = img.size
    cols = W // IMG_SIZE
    rows = H // IMG_SIZE
    if cols == 0 or rows == 0:
        print(f"[WARN] {ref_path} not divisible by {IMG_SIZE}; skipping.")
        return 0

    out_dir = out_root/split
    out_dir.mkdir(parents=True, exist_ok=True)

    saved = 0
    for r in range(rows):
        for c in range(cols):
            # Skip the first column if it is the source image (common StarGAN grid convention).
            if c == 0: 
                continue
            tile = img.crop((c*IMG_SIZE, r*IMG_SIZE, (c+1)*IMG_SIZE, (r+1)*IMG_SIZE))
            fname = f"{split}_r{r:04d}_c{c:04d}.png"
            fpath = out_dir/fname
            tile.save(fpath, "PNG")

            # Stage a metadata row for this tile (source/target species unknown from grid alone)
            new_rows.append({
                "id": fpath.stem,
                "path": str(fpath),
                "split": split,
                "species_src": "",         # unknown from grid; leave blank
                "species_tgt": "",
                "label": "fake",
                "gen_family": "stargan_v2",
                "seed": "",
                "ref_id": "",
                "source": "generated_grid"
            })
            saved += 1
    return saved

total_saved = 0
for sp in splits:
    ref = in_root/f"{sp}_all"/"reference.jpg"
    if ref.exists():
        print(f"Slicing {ref} ...")
        total_saved += slice_grid(ref, sp)
    else:
        print(f"[INFO] No {ref} (did sampling finish for {sp}?)")

print(f"\nSaved {total_saved} tiles to {out_root}")

