# === Merge AFHQ + AFHQ-v2 into a single deduplicated tree (data/afhq_all) with deterministic split ===
import os, hashlib, random, shutil
from pathlib import Path

random.seed(42)  # reproducibility for any sampling/shuffling
root = Path.cwd()
src_roots = [root/"data/afhq", root/"data/afhq-v2"]  # sources to merge
dst_root  = root/"data/afhq_all"                     # unified destination
species = ["cat","dog","wild"]
splits  = ["train","val","holdout"]
ratios  = {"train":0.70, "val":0.15, "holdout":0.15} # deterministic split ratios

# 1) Collect all image paths by species across both datasets (handles possible train/val/test layouts)
all_paths = []
for s in species:
    for src in src_roots:
        for split_guess in ["train","val","test",""]:
            d = src/split_guess/s
            if d.exists():
                all_paths += [(s, p) for p in d.rglob("*") if p.suffix.lower() in [".jpg",".jpeg",".png"]]

# 2) Deduplicate within each species by SHA-1 (prevents leakage & duplicates across sources)
def sha1(fp, chunk=1<<20):
    h = hashlib.sha1()
    with open(fp,"rb") as f:
        for b in iter(lambda: f.read(chunk), b""):
            h.update(b)
    return h.hexdigest()

seen, dedup = set(), {s: [] for s in species}
for s, p in all_paths:
    try:
        h = sha1(p)
    except Exception:
        continue
    key = (s,h)
    if key not in seen:
        seen.add(key)
        dedup[s].append(p)

# 3) Deterministic split by stable hash of filepath (no random data leakage between splits)
def det_bucket(path):
    h = int(hashlib.md5(str(path).encode()).hexdigest(), 16) / (1<<128)
    if h < ratios["train"]: return "train"
    if h < ratios["train"]+ratios["val"]: return "val"
    return "holdout"

# Ensure destination folders exist
for split in splits:
    for s in species:
        (dst_root/split/s).mkdir(parents=True, exist_ok=True)

# Place files via symlink (falls back to copy on systems without symlink support)
for s in species:
    for p in dedup[s]:
        split = det_bucket(p)
        dst = dst_root/split/s/p.name
        if not dst.exists():
            try: os.symlink(p, dst)
            except OSError: shutil.copy2(p, dst)

# Report counts per split/species
print("Done. Sample counts:")
for split in splits:
    print(split, {s: len(list((dst_root/split/s).glob('*'))) for s in species})

# === Build small per-split reference trees used by StarGAN-v2 sampler (N examples per species) ===
from pathlib import Path
import os, random, shutil

base = Path.cwd()
real_root = base/"data/afhq_all"

def make_ref_tree(split, n_per_domain=10):
    """
    Create tmp_refs/<split>/<species>/ with up to n_per_domain real images per species.
    These are used as 'reference' styles for StarGAN-v2 sampling.
    """
    ref_root = base/f"tmp_refs/{split}"
    for dom in ["cat","dog","wild"]:
        d = ref_root/dom
        d.mkdir(parents=True, exist_ok=True)
        for f in d.glob("*"): f.unlink()  # clear any prior content
        imgs = [p for p in (real_root/split/dom).glob("*") if p.suffix.lower() in [".jpg",".jpeg",".png"]]
        random.shuffle(imgs)
        for p in imgs[:min(n_per_domain, len(imgs))]:
            try: os.symlink(p, d/p.name)
            except OSError: shutil.copy2(p, d/p.name)
    return ref_root

# Create refs for each split
for sp in ["train","val","holdout"]:
    print("Created refs at:", make_ref_tree(sp))

